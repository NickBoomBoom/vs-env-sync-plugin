{
  "name": "vs-env-sync-plugin",
  "displayName": "Git 项目 Env 同步",
  "description": "通过专用仓库自动拉取、导出并备份每个 Git 项目的 env 文件。",
  "version": "0.1.2",
  "publisher": "NickBoomBoom",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "vscode": "^1.112.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "env",
    "dotenv",
    "environment",
    "git",
    "sync",
    "github",
    "secrets"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "pricing": "Free",
  "markdown": "github",
  "repository": {
    "type": "git",
    "url": "https://github.com/NickBoomBoom/vs-env-sync-plugin.git"
  },
  "homepage": "https://github.com/NickBoomBoom/vs-env-sync-plugin#readme",
  "bugs": {
    "url": "https://github.com/NickBoomBoom/vs-env-sync-plugin/issues"
  },
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false
    },
    "virtualWorkspaces": {
      "supported": false
    }
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:envSync.initializeConfigRepo"
  ],
  "main": "./dist/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "envSync.initializeConfigRepo",
        "title": "Env Sync：初始化配置仓库"
      }
    ],
    "configuration": {
      "title": "Env Sync",
      "properties": {
        "envSync.configRepoUrl": {
          "type": "string",
          "default": "",
          "description": "用于存储同步环境文件的私有 Git 仓库 URL。"
        },
        "envSync.configRepoBranch": {
          "type": "string",
          "default": "main",
          "description": "配置仓库使用的分支名称。"
        },
        "envSync.pathRegexes": {
          "type": "array",
          "default": [
            "^\\.env[^/]*$"
          ],
          "items": {
            "type": "string"
          },
          "description": "用于匹配 Git 项目相对 POSIX 路径的 JavaScript 正则表达式。任意正则匹配时，该文件会被同步。"
        },
        "envSync.gitProjectSearchDepth": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "description": "在工作区根目录下搜索 Git 项目的目录层级。0 表示仅搜索工作区根目录。"
        },
        "envSync.gitProjectIgnoreDirectories": {
          "type": "array",
          "default": [
            "node_modules",
            "dist",
            "build",
            ".next",
            ".turbo",
            ".pnpm-store"
          ],
          "items": {
            "type": "string"
          },
          "description": "在工作区根目录下递归搜索 Git 项目时要跳过的目录名称。"
        },
        "envSync.notificationLevel": {
          "type": "string",
          "enum": [
            "errors",
            "summary",
            "all"
          ],
          "default": "summary",
          "description": "控制 Env Sync 通过 VS Code 通知报告的详细程度。'errors' 仅显示失败，'summary' 显示有意义的同步摘要，'all' 还会显示无变更检查。"
        },
        "envSync.pathRegex": {
          "type": "string",
          "default": "",
          "markdownDeprecationMessage": "请改用 `envSync.pathRegexes`。此旧设置仅作为旧版配置的兜底项保留。",
          "description": "已弃用的旧版单个正则兜底配置。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist .tmp-test-workspace",
    "test": "npm run build && mocha \"dist/test/**/*.test.js\"",
    "package:vsix": "vsce package",
    "deploy": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/vscode": "1.110.0",
    "mocha": "^11.7.1",
    "typescript": "^5.8.3"
  }
}
